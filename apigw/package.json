{
  "name": "evaka-api-gateways",
  "version": "1.0.0",
  "description": "API gateways for eVaka",
  "type": "module",
  "private": true,
  "license": "LGPL-2.1-or-later",
  "scripts": {
    "clean": "rm -rf ./build ./dist",
    "type-check": "tsc",
    "lint": "eslint --max-warnings 0 .",
    "lint:fix": "yarn lint --fix",
    "test": "NODE_ENV=test vitest run",
    "dev": "concurrently --prefix '[{name}]' --names 'tsc,node' 'tsc --preserveWatchOutput --watch' 'NODE_ENV=local node --watch-preserve-output --watch src/index.ts'",
    "prepack": "exit 1"
  },
  "dependencies": {
    "@node-saml/node-saml": "5.1.0",
    "axios": "1.15.0",
    "connect-redis": "9.0.0",
    "cookie-parser": "1.4.7",
    "cookie-signature": "1.2.2",
    "date-fns": "4.1.0",
    "dd-trace": "5.97.0",
    "express": "5.2.1",
    "express-basic-auth": "1.2.1",
    "express-http-proxy": "2.1.2",
    "express-session": "1.19.0",
    "fast-xml-parser": "5.7.0",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.3",
    "lodash": "4.18.1",
    "make-error-cause": "2.3.0",
    "nocache": "4.0.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "pino-pretty": "13.1.3",
    "pump": "3.0.4",
    "query-string": "9.3.1",
    "redis": "5.12.1",
    "split2": "4.2.0",
    "through2": "4.0.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/cookie-parser": "1.4.10",
    "@types/cookie-signature": "1.1.2",
    "@types/express-http-proxy": "1.6.7",
    "@types/express-session": "1.18.2",
    "@types/jsonwebtoken": "9.0.10",
    "@types/lodash": "4.17.24",
    "@types/node": "24.12.2",
    "@types/node-forge": "1.3.14",
    "@types/pump": "1.1.3",
    "@types/split2": "4.2.3",
    "@types/through2": "2.0.41",
    "@types/tough-cookie": "4.0.5",
    "@types/xml2js": "0.4.14",
    "concurrently": "9.2.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.5",
    "nock": "14.0.13",
    "node-forge": "1.4.0",
    "prettier": "3.8.2",
    "tough-cookie": "6.0.1",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.2",
    "vitest": "latest",
    "xml-crypto": "6.1.2",
    "xml2js": "0.6.2"
  },
  "prettier": {
    "arrowParens": "always",
    "bracketSpacing": true,
    "semi": false,
    "singleQuote": true,
    "trailingComma": "none"
  },
  "engines": {
    "node": ">= 22.18.0"
  },
  "packageManager": "yarn@4.13.0"
}
