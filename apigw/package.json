{
  "name": "evaka-api-gateways",
  "version": "1.0.0",
  "private": true,
  "description": "API gateways for eVaka",
  "license": "LGPL-2.1-or-later",
  "type": "module",
  "scripts": {
    "clean": "rm -rf ./build ./dist",
    "type-check": "tsc",
    "lint": "oxfmt -c ../.oxfmtrc.json --check && oxlint",
    "lint:fix": "oxfmt -c ../.oxfmtrc.json && oxlint --fix",
    "test": "NODE_ENV=test vitest run",
    "dev": "concurrently --prefix '[{name}]' --names 'tsc,node' 'tsc --preserveWatchOutput --watch' 'NODE_ENV=local node --watch-preserve-output --watch src/index.ts'",
    "prepack": "exit 1"
  },
  "dependencies": {
    "@node-saml/node-saml": "5.1.0",
    "axios": "1.18.1",
    "connect-redis": "9.0.0",
    "cookie-parser": "1.4.7",
    "cookie-signature": "1.2.2",
    "date-fns": "4.4.0",
    "dd-trace": "5.109.0",
    "express": "5.2.1",
    "express-basic-auth": "1.2.1",
    "express-http-proxy": "2.1.2",
    "express-session": "1.19.0",
    "fast-xml-parser": "5.9.3",
    "helmet": "8.2.0",
    "jsonwebtoken": "9.0.3",
    "lodash": "4.18.1",
    "make-error-cause": "2.3.0",
    "nocache": "4.0.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "pino-pretty": "13.1.3",
    "pump": "3.0.4",
    "query-string": "9.4.1",
    "redis": "6.0.1",
    "split2": "4.2.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "1.4.10",
    "@types/cookie-signature": "1.1.2",
    "@types/express-http-proxy": "1.6.7",
    "@types/express-session": "1.19.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/lodash": "4.17.24",
    "@types/node": "24.13.2",
    "@types/node-forge": "1.3.14",
    "@types/pump": "1.1.3",
    "@types/split2": "4.2.3",
    "@types/tough-cookie": "4.0.5",
    "@types/xml2js": "0.4.14",
    "concurrently": "10.0.3",
    "nock": "14.0.16",
    "node-forge": "1.4.0",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "oxlint-tsgolint": "0.23.0",
    "tough-cookie": "6.0.1",
    "typescript": "6.0.3",
    "vitest": "4.1.9",
    "xml-crypto": "6.1.2",
    "xml2js": "0.6.2"
  },
  "resolutions": {
    "tar": "7.5.16"
  },
  "engines": {
    "node": ">= 22.18.0"
  },
  "packageManager": "yarn@4.17.0"
}
