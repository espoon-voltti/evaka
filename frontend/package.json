{
  "name": "evaka-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "Frontend for eVaka",
  "license": "LGPL-2.1-or-later",
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist screenshots videos node_modules/.cache",
    "dev": "concurrently -n tsc,vite -c blue,green 'yarn type-check:watch' 'vite --host'",
    "lint": "oxfmt --check && oxlint",
    "lint:fix": "oxfmt && oxlint --fix",
    "type-check": "tsc --build --force .",
    "type-check:watch": "yarn type-check --watch --preserveWatchOutput",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev-maintenance-page": "cd src/maintenance-page-frontend && npx http-server",
    "e2e": "LC_ALL=fi_FI.UTF-8 tsx node_modules/.bin/playwright test -c src/e2e-test/playwright.config.ts"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "7.2.0",
    "@fortawesome/free-regular-svg-icons": "7.2.0",
    "@fortawesome/free-solid-svg-icons": "7.2.0",
    "@fortawesome/react-fontawesome": "3.3.1",
    "@react-spring/web": "10.1.1",
    "@sentry/browser": "10.58.0",
    "@sentry/react": "10.58.0",
    "@tanstack/react-query": "5.101.0",
    "autosize": "6.0.1",
    "axios": "1.18.1",
    "chart.js": "4.5.1",
    "chartjs-adapter-date-fns": "3.0.0",
    "chartjs-plugin-annotation": "3.1.0",
    "classnames": "2.5.1",
    "csstype": "3.2.3",
    "date-fns": "4.4.0",
    "date-fns-tz": "3.2.0",
    "leaflet": "1.9.4",
    "lib-common": "link:src/lib-common",
    "lib-components": "link:src/lib-components",
    "lib-customizations": "link:src/lib-customizations",
    "lib-icons": "link:src/lib-icons",
    "linkify-it": "5.0.1",
    "lodash": "4.18.1",
    "polished": "4.3.1",
    "punycode": "2.3.1",
    "react": "19.2.7",
    "react-chartjs-2": "5.3.1",
    "react-day-picker": "10.0.1",
    "react-dom": "19.2.7",
    "react-focus-lock": "2.13.7",
    "react-focus-on": "3.10.2",
    "react-image-crop": "11.0.10",
    "react-leaflet": "5.0.0",
    "react-select": "5.10.2",
    "seamless-scroll-polyfill": "2.3.4",
    "styled-components": "6.3.12",
    "wouter": "3.10.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@sentry/vite-plugin": "5.3.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/autosize": "4.0.3",
    "@types/leaflet": "1.9.21",
    "@types/linkify-it": "5.0.0",
    "@types/lodash": "4.17.24",
    "@types/node": "24.13.2",
    "@types/punycode": "2.1.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-legacy": "8.0.2",
    "@vitejs/plugin-react": "6.0.2",
    "concurrently": "10.0.3",
    "eslint-plugin-lodash": "8.0.0",
    "jsdom": "29.1.1",
    "make-error-cause": "2.3.0",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "playwright": "1.61.0",
    "postcss": "8.5.15",
    "postcss-preset-env": "11.3.1",
    "rollup": "4.62.2",
    "terser": "5.48.0",
    "ts-node": "10.9.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vitest": "4.1.9"
  },
  "peerDependencies": {
    "@fortawesome/pro-light-svg-icons": "7.2.0",
    "@fortawesome/pro-regular-svg-icons": "7.2.0",
    "@fortawesome/pro-solid-svg-icons": "7.2.0"
  },
  "peerDependenciesMeta": {
    "@fortawesome/pro-light-svg-icons": {
      "optional": true
    },
    "@fortawesome/pro-regular-svg-icons": {
      "optional": true
    },
    "@fortawesome/pro-solid-svg-icons": {
      "optional": true
    }
  },
  "resolutions": {
    "@react-leaflet/core@npm:^3.0.0": "patch:@react-leaflet/core@npm%3A3.0.0#~/.yarn/patches/@react-leaflet-core-npm-3.0.0-4e3f2d62b5.patch",
    "postcss": "8.5.15",
    "tar": "7.5.16"
  },
  "browserslist": [
    "Firefox ESR",
    "last 2 Chrome versions",
    "last 2 Android versions",
    "last 2 FirefoxAndroid versions",
    "last 2 ChromeAndroid versions",
    "last 2 Safari versions",
    "last 2 iOS versions",
    "last 2 Edge versions",
    "last 2 Samsung versions",
    "> 5% in FI",
    "last 3 years"
  ],
  "engines": {
    "node": ">= 22.12.0"
  },
  "packageManager": "yarn@4.17.0",
  "postcss": {
    "plugins": {
      "postcss-preset-env": true
    }
  }
}
